# ============================================================
# MeowTrain — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# ── Database ──────────────────────────────────────────────────
# SQLite (default, good for local dev):
MEOWLLM_DATABASE_URL=sqlite:///./data/meowllm.db
# PostgreSQL (recommended for production):
# MEOWLLM_DATABASE_URL=postgresql://user:password@localhost:5432/meowllm

# ── Security ──────────────────────────────────────────────────
# REQUIRED in production — generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
MEOWLLM_JWT_SECRET=change-me-to-a-random-secret-key
MEOWLLM_JWT_EXPIRY_HOURS=24

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins
MEOWLLM_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Upload ───────────────────────────────────────────────
# Maximum upload size in MB
MEOWLLM_MAX_UPLOAD_MB=100

# ── Data Storage ──────────────────────────────────────────────
# Base directory for projects, models, and cache
MEOWLLM_DATA_DIR=./data

# ── HuggingFace ───────────────────────────────────────────────
# Required for gated models (Llama, Mistral, etc.)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Allow models to execute arbitrary code on load (SECURITY RISK)
# Only enable if you trust every model you use
MEOWLLM_TRUST_REMOTE_CODE=false

# ── Rate Limiting ─────────────────────────────────────────────
MEOWLLM_RATE_LIMIT_AUTH=5/minute
MEOWLLM_RATE_LIMIT_INFERENCE=10/minute
MEOWLLM_RATE_LIMIT_UPLOAD=10/minute

# ── Guest Accounts ────────────────────────────────────────────
MEOWLLM_GUEST_MAX_PROJECTS=3
MEOWLLM_GUEST_CLEANUP_DAYS=7

# ── Logging ───────────────────────────────────────────────────
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
MEOWLLM_LOG_LEVEL=INFO
# Format: text (human-readable) or json (structured, for log aggregators)
MEOWLLM_LOG_FORMAT=text

# ── Email / SMTP (optional) ──────────────────────────────────
# Required for email verification and password reset emails.
# If not configured, verification tokens are logged to console.
MEOWLLM_SMTP_HOST=
MEOWLLM_SMTP_PORT=587
MEOWLLM_SMTP_USER=
MEOWLLM_SMTP_PASSWORD=
MEOWLLM_SMTP_FROM=noreply@example.com

# ── OAuth (optional) ─────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
MEOWLLM_OAUTH_GOOGLE_CLIENT_ID=
MEOWLLM_OAUTH_GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
MEOWLLM_OAUTH_GITHUB_CLIENT_ID=
MEOWLLM_OAUTH_GITHUB_CLIENT_SECRET=

# Base URL for OAuth redirect callbacks
MEOWLLM_OAUTH_REDIRECT_BASE=http://localhost:5173

# ── Frontend URL ──────────────────────────────────────────────
# Used in email templates for verification/reset links
MEOWLLM_FRONTEND_URL=http://localhost:5173

# ── Server ────────────────────────────────────────────────────
MEOWLLM_HOST=0.0.0.0
MEOWLLM_PORT=8000
