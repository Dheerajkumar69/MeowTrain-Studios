# ===== MeowLLM Studio Configuration =====
# Copy this file to .env and edit the values

# REQUIRED: Change this to a random string (e.g., run: python -c "import secrets; print(secrets.token_urlsafe(32))")
MEOWLLM_JWT_SECRET=change-this-to-a-random-secret-key

# CORS origins (comma-separated)
MEOWLLM_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Maximum upload file size in MB
MEOWLLM_MAX_UPLOAD_MB=100

# HuggingFace token (required for gated models like Llama)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Database URL (default: SQLite)
MEOWLLM_DATABASE_URL=sqlite:///./meowllm.db

# Server settings
MEOWLLM_HOST=0.0.0.0
MEOWLLM_PORT=8000
